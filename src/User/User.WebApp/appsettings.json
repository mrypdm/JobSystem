{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Expressions"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": {
            "type": "Serilog.Templates.ExpressionTemplate, Serilog.Expressions",
            "template": "[{@t:HH:mm:ss}{#if IsCritical is not null} CRIT{#end} {@l:u3}] [{SourceContext}] {@m}\n{@x}"
          }
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "/var/log/user-webapp/log.json",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "formatter": {
            "type": "Serilog.Formatting.Json.JsonFormatter, Serilog",
            "renderMessage": true
          }
        }
      }
    ]
  },
  "HostOptions": {
    "ShutdownTimeout": "00:05:00"
  },
  "Urls": "https://*:443;http://*:80",
  "WebServerOptions": {
    "CertificateFilePath": "/etc/user-webapp.d/svc_users_webapp.keystore.p12",
    "Password": ""
  },
  "DatabaseOptions": {
    "HostName": "localhost",
    "Port": 5432,
    "DatabaseName": "Users",
    "RetriesCount": 10,
    "RetryDelay": "00:01:00",
    "CertificateFilePath": "/etc/user-webapp.d/svc_users_webapp@postgres.keystore.p12",
    "Password": "",
    "RevocationListFilePath": "/etc/user-webapp.d/crl.pem"
  },
  "JobWebApiClientOptions": {
    "Url": "https://localhost:5000/",
    "Timeout": "00:00:30",
    "CertificateFilePath": "/etc/user-webapp.d/svc_users_webapp@webapi.keystore.p12",
    "Password": "",
    "RevocationListFilePath": "/etc/user-webapp.d/crl.pem"
  }
}
