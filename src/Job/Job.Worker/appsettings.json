{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Expressions"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": {
            "type": "Serilog.Templates.ExpressionTemplate, Serilog.Expressions",
            "template": "[{@t:HH:mm:ss}{#if IsCritical is not null} CRIT{#end} {@l:u3}] [{SourceContext}] {@m}\n{@x}"
          }
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "/var/log/job-worker/log.json",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "formatter": {
            "type": "Serilog.Formatting.Json.JsonFormatter, Serilog",
            "renderMessage": true
          }
        }
      }
    ]
  },
  "HostOptions": {
    "ShutdownTimeout": "01:00:00"
  },
  "DatabaseOptions": {
    "HostName": "localhost",
    "Port": 5432,
    "DatabaseName": "Jobs",
    "RetriesCount": 10,
    "RetryDelay": "00:01:00",
    "CertificateFilePath": "/etc/job-worker.d/svc_jobs_worker@postgres.keystore.p12",
    "Password": "",
    "RevocationListFilePath": "/etc/job-worker.d/crl.pem"
  },
  "ConsumerOptions": {
    "GroupId": "Job.Worker.Group",
    "Topic": "Jobs",
    "Servers": "localhost:8500",
    "TruststoreFilePath": "/etc/job-worker.d/svc_kafka.truststore.pem",
    "CertificateFilePath": "/etc/job-worker.d/svc_jobs_worker@kafka.crt",
    "KeyFilePath": "/etc/job-worker.d/svc_jobs_worker@kafka.key",
    "Password": "",
    "RevocationListFilePath": "/etc/job-worker.d/crl.pem"
  },
  "JobEnvironmentOptions": {
    "JobsDirectory": "/tmp/jobs",
    "CpuUsage": "0.5",
    "MemoryUsage": "512"
  },
  "ResourcesAnalyzerOptions": {
    "ThresholdCpuUsage": "0.8",
    "ThresholdMemoryUsage": "0.8",
    "ThresholdDriveUsage": "0.8",
    "ThresholdRunningJobs": 16
  },
  "ConsumerWorkerOptions": {
    "IterationDeplay": "00:00:10"
  }
}
