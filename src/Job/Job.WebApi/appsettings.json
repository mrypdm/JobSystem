{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Expressions"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": {
            "type": "Serilog.Templates.ExpressionTemplate, Serilog.Expressions",
            "template": "[{@t:HH:mm:ss}{#if IsCritical is not null} CRIT{#end} {@l:u3}] [{SourceContext}] {@m}\n{@x}"
          }
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "/var/log/job-webapi/log.json",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "formatter": {
            "type": "Serilog.Formatting.Json.JsonFormatter, Serilog",
            "renderMessage": true
          }
        }
      }
    ]
  },
  "HostOptions": {
    "ShutdownTimeout": "00:05:00"
  },
  "Urls": "https://*:443;http://*:80",
  "WebServerOptions": {
    "CertificateFilePath": "/etc/job-webapi.d/svc_jobs_webapi.keystore.p12",
    "Password": "",
    "RevocationListFilePath": "/etc/job-webapi.d/crl.pem"
  },
  "JobControllerOptions": {
    "DefaultTimeout": "00:10:00",
    "MaxTimeout": "00:45:00"
  },
  "DatabaseOptions": {
    "HostName": "localhost",
    "Port": 5432,
    "DatabaseName": "Jobs",
    "RetriesCount": 10,
    "RetryDelay": "00:30:00",
    "CertificateFilePath": "/etc/job-webapi.d/svc_jobs_webapi@postgres.keystore.p12",
    "Password": "",
    "RevocationListFilePath": "/etc/job-webapi.d/crl.pem"
  },
  "LostJobWorkerOptions": {
    "IsEnabled": true,
    "IterationDeplay": "00:15:00",
    "LostTimeoutForJobs": "01:00:00"
  },
  "ProducerOptions": {
    "Topic": "Jobs",
    "Servers": "localhost:8500",
    "TruststoreFilePath": "/etc/job-webapi.d/svc_kafka.truststore.pem",
    "CertificateFilePath": "/etc/job-webapi.d/svc_jobs_webapi@kafka.crt",
    "KeyFilePath": "/etc/job-webapi.d/svc_jobs_webapi@kafka.key",
    "Password": "",
    "RevocationListFilePath": "/etc/job-webapi.d/crl.pem"
  }
}
