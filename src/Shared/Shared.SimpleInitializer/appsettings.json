{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": {
            "type": "Serilog.Templates.ExpressionTemplate, Serilog.Expressions",
            "template": "[{@t:HH:mm:ss}{#if IsCritical is not null} CRIT{#end} {@l:u3}] [{SourceContext}] {@m}\n{@x}"
          }
        }
      }
    ]
  },
  "AdminOptions": {
    "PartitionsCount": 3,
    "ReplicationFactor": 1,
    "Topic": "Jobs",
    "Servers": "localhost:8500",
    "TruststoreFilePath": "Config/svc_kafka.truststore.pem",
    "CertificateFilePath": "Config/superuser@kafka.crt",
    "KeyFilePath": "Config/superuser@kafka.key",
    "Password": "qwerty-123",
    "RevocationListFilePath": "Config/crl.pem"
  },
  "AdminJobsDatabaseOptions": {
    "HostName": "localhost",
    "Port": 5432,
    "DatabaseName": "Jobs",
    "RetriesCount": 10,
    "RetryDelay": "00:01:00",
    "CertificateFilePath": "Config/superuser@postgres.keystore.p12",
    "Password": "qwerty-123",
    "RevocationListFilePath": "Config/crl.pem"
  },
  "AdminUsersDatabaseOptions": {
    "HostName": "localhost",
    "Port": 5432,
    "DatabaseName": "Users",
    "RetriesCount": 10,
    "RetryDelay": "00:01:00",
    "CertificateFilePath": "Config/superuser@postgres.keystore.p12",
    "Password": "qwerty-123",
    "RevocationListFilePath": "Config/crl.pem"
  }
}
